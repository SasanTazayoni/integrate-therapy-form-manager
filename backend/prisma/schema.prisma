generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  dob              DateTime?
  status           String    @default("active")
  inactivated_at   DateTime?
  delete_inactive  DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  forms            Form[]

  @@index([status, delete_inactive])
}

model Form {
  id               String    @id @default(uuid())
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         String
  form_type        String
  token            String    @unique
  token_sent_at    DateTime
  token_expires_at DateTime
  is_active        Boolean   @default(true)
  submitted_at     DateTime?
  revoked_at       DateTime?
  bdi_score        Int?
  bai_score        Int?
  ysq_ed_score     Int?
  ysq_ab_score     Int?
  ysq_ma_score     Int?
  ysq_si_score     Int?
  ysq_ds_score     Int?
  ysq_fa_score     Int?
  ysq_di_score     Int?
  ysq_vu_score     Int?
  ysq_eu_score     Int?
  ysq_sb_score     Int?
  ysq_ss_score     Int?
  ysq_ei_score     Int?
  ysq_us_score     Int?
  ysq_et_score     Int?
  ysq_is_score     Int?
  ysq_as_score     Int?
  ysq_np_score     Int?
  ysq_pu_score     Int?
  ysq_ed_456       Int?
  ysq_ab_456       Int?
  ysq_ma_456       Int?
  ysq_si_456       Int?
  ysq_ds_456       Int?
  ysq_fa_456       Int?
  ysq_di_456       Int?
  ysq_vu_456       Int?
  ysq_eu_456       Int?
  ysq_sb_456       Int?
  ysq_ss_456       Int?
  ysq_ei_456       Int?
  ysq_us_456       Int?
  ysq_et_456       Int?
  ysq_is_456       Int?
  ysq_as_456       Int?
  ysq_np_456       Int?
  ysq_pu_456       Int?
  smi_dp_score     Float?
  smi_dss_score    Float?
  smi_ba_score     Float?
  smi_sa_score     Float?
  smi_cs_score     Float?
  smi_ic_score     Float?
  smi_uc_score     Float?
  smi_cc_score     Float?
  smi_vc_score     Float?
  smi_dc_score     Float?
  smi_pp_score     Float?
  smi_ac_score     Float?
  smi_ec_score     Float?
  smi_ha_score     Float?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([clientId])
}
